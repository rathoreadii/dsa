class Solution {
public:
    bool isPalindrome(string s) {
        string st= "";
        for(auto c: s){
            if(c == ' ')
                continue;
            st+= c;
        }

        cout<< st;
        
        int i= 0, j= st.length()-1;
        while(i<j){
            while(i<j && !isalnum(st[i]))
                i++;
            while(i<j && !isalnum(st[j]))
                j--;

            if(tolower(st[i]) != tolower(st[j]))
                return false;
            
            i++;
            j--;
        }

        return true;
    }
};
