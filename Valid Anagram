class Solution {
public:
    bool isAnagram(string s, string t) {
        if (s.length() != t.length()) return false;
        unordered_map<char, int> c;
        for(auto i: s)
            c[i]++;
        
        for(auto i: t)
        {
            if(c[i] == 0)
                return false;
            c[i]--;
        }

        return true;
    }
};
