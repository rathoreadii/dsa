class Solution {
public:
    bool isValidSudoku(vector<vector<char>>& board) {
        vector<vector<bool>> rows(9, vector<bool>(9, false));
        vector<vector<bool>> cols(9, vector<bool>(9, false));
        vector<vector<bool>> boxes(9, vector<bool>(9, false));

        for(int i= 0; i< 9; i++){
            for(int j= 0; j< 9; j++){
                char curr= board[i][j];
                if(curr == '.')
                    continue;
                
                int num= curr - '1';
                int box= (i/3)*3 + (j/3);

                if(rows[i][num] ||
                    cols[j][num] ||
                    boxes[box][num])
                        return false;
                
                rows[i][num]= curr;
                cols[j][num]= curr;
                boxes[box][num]= curr;
            }
        }

        return true;
    }
};
